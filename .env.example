# Spark and JVM
SPARK_VERSION=4.1.1
SPARK_HADOOP_PROFILE=hadoop3
SCALA_VERSION=2.13.17
SBT_VERSION=1.10.7
JAVA_BASE_IMAGE=eclipse-temurin:17.0.13_11-jdk-jammy

# Official Apache Spark distribution mirror used by docker/spark-client/Dockerfile.
# archive.apache.org is stable for reproducible builds.
APACHE_SPARK_DIST_BASE_URL=https://archive.apache.org/dist/spark

# Redpanda is optional and only starts with the "streaming" Docker Compose profile.
REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:v26.1.5

# Local demo sizing
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# Spark UI and History Server
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_EVENT_LOG_DIR=file:/opt/spark-events
SPARK_HISTORY_LOG_DIR=file:/opt/spark-events
